{
  "name": "robo-advisor-server",
  "version": "1.0.0",
  "description": "Node.js backend for NLP-based Risk Profiler & Robo-Advisor",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:render": "node server_render.js",
    "dev": "nodemon server.js",
